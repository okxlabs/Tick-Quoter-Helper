ecode differs — that's fine,\n        //    it's behind the proxy and users don't interact with it directly.\n        bytes32 implSalt = keccak256(abi.encodePacked(\"QueryCurveUpgradeable\"));\n        address implementation = deployImplementation(implSalt);\n\n        // 2. Deploy one-time factory via CREATE2 → same address on all chains\n        //    (factory bytecode is chain-agnostic)\n        console2.log(\"Deploying ProxyDeployFactory...\");\n        bytes32 factorySalt = keccak256(abi.encodePacked(\"QueryCurveProxyFactory\"));\n        address factory = create2Deploy(factorySalt, type(ProxyDeployFactory).creationCode);\n\n        // 3. Deploy proxy from factory via CREATE\n        //    factory_address is the same on all chains, nonce is 1 (first CREATE from factory)\n        //    → proxy address is deterministic across chains, regardless of implementation\n        console2.log(\"Deploying ERC1967Proxy via factory...\");\n        bytes memory initData = abi.encodeWithSignature(\"initialize(address)\", owner);\n        address proxy = ProxyDeployFactory(factory).deploy(implementation, initData);\n        console2.log(\"  =\u003e Proxy:\", proxy);\n\n        // 4. Verify\n        console2.log(\"--- Verification ---\");\n        console2.log(\"Owner:\", QueryCurveUpgradeable(proxy).owner());\n        console2.log(\"Meta register:\", QueryCurveUpgradeable(proxy).meta_register());\n\n        vm.stopBroadcast();\n    }\n}\n",
