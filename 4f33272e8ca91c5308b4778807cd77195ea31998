              "content": "// SPDX-License-Identifier: MIT\npragma solidity ^0.8.17;\n\nimport {Script, console2} from \"forge-std/Script.sol\";\nimport {ERC1967Proxy} from \"@openzeppelin/contracts/proxy/ERC1967/ERC1967Proxy.sol\";\nimport {QueryCurveUpgradeable} from \"../src/Curve/QueryCurveUpgradeable.sol\";\n\n/// @notice One-time factory for cross-chain deterministic proxy deployment.\n///\n/// How it works:\n///   1. This factory is deployed via CREATE2 → same factory address on ALL chains\n///   2. Factory deploys the proxy via CREATE (nonce-based)\n///   3. Since factory_address + nonce(1) are identical across chains,\n///      the proxy gets the SAME address regardless of implementation address or bytecode\n///\n/// This solves the problem where implementation bytecode differs per chain\n/// (e.g. QueryCurveUpgradeableBase vs QueryCurveUpgradeablePolygon)\n/// but the proxy address must remain the same.\ncontract ProxyDeployFactory {\n    bool public used;\n\n    function deploy(address implementation, bytes memory data) external returns (address) {\n        require(!used, \"factory already used\");\n        used = true;\n        return address(new ERC1967Proxy(implementation, data));\n    }\n}\n\ncontract DeployQueryCurveUpgradeable is Script {\n    address internal constant DETERMINISTIC_DEPLOYER = 0x4e59b44847b379578588920cA78FbF26c0B4956C;\n\n    function setUp() public virtual {}\n\n    /// @notice Deploy contract via CREATE2 through the deterministic deployer (nick's method)\n    /// @dev Address = keccak256(0xff ++ deployer ++ salt ++ keccak256(initCode))[12:]\n    ///      Independent of sender nonce — only depends on salt and initCode.\n    function create2Deploy(bytes32 salt, bytes memory initCode) internal returns (address addr) {\n        (bool success, bytes memory result) = DETERMINISTIC_DEPLOYER.call{value: 0}(\n            abi.encodePacked(salt, initCode)\n        );\n        require(success, \"CREATE2 deployment failed\");\n\n        // The